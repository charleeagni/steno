{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steno",
  "version": "0.1.0",
  "identifier": "com.karthik.steno",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Steno",
        "width": 920,
        "height": 760,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Steno Recording",
        "url": "/?overlay=1",
        "width": 900,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../assets/models/silero_vad.onnx"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
