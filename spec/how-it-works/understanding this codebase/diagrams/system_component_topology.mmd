graph LR
  subgraph Frontend["Frontend Windows (React + TypeScript)"]
    Main["main window (App.tsx)"]
    Overlay["overlay window (OverlayApp.tsx)"]
    Bridge["tauri.ts bridge (invoke/listen)"]
  end

  subgraph Shell["Tauri Shell (Rust)"]
    Commands["lib.rs command handlers + tray lifecycle"]
    Runtime["RuntimeController (runtime.rs)"]
    Downloads["ModelDownloadManager (model_download.rs)"]
    Events["Event emitter (steno://*)"]
  end

  subgraph External["macOS / External Systems"]
    Mic["Microphone capture via cpal"]
    Hotkeys["Global hotkeys via handy-keys"]
    Clip["Clipboard plugin"]
    Apple["System Events via osascript"]
    Hub["Hugging Face Hub + local cache"]
    Core["transcriber-core (Whisper/Parakeet)"]
    Config["settings.json in app config dir"]
    Temp["Temporary WAV/TXT in /tmp/steno"]
  end

  Main --> Bridge
  Overlay --> Bridge
  Bridge --> Commands
  Commands --> Runtime
  Commands --> Downloads
  Runtime --> Events
  Downloads --> Events
  Events --> Main
  Events --> Overlay

  Runtime --> Mic
  Runtime --> Hotkeys
  Runtime --> Clip
  Runtime --> Apple
  Runtime --> Core
  Runtime --> Config
  Runtime --> Temp

  Downloads --> Hub
  Downloads --> Config
